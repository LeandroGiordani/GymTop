<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only manifest overlay. Merged on top of main/AndroidManifest.xml for debug builds.
    Icon and theme are inherited from the main manifest — MissingApplicationIcon is a false positive.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingApplicationIcon">

    <application
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">

        <!--
            App Startup: registra os initializers do emulador apenas em debug builds.
            Em release, este manifest não é mergeado, portanto os emuladores nunca são ativados.
            Firebase Auth e Firestore se auto-inicializam em produção via getInstance().
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">

            <meta-data
                android:name="com.example.gymtop.util.AuthInitializer"
                android:value="androidx.startup" />

            <meta-data
                android:name="com.example.gymtop.util.FirestoreInitializer"
                android:value="androidx.startup" />

        </provider>

    </application>

</manifest>
