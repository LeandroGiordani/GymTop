rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasOnlyAllowedProfileFields() {
      return request.resource.data.keys().hasOnly(['name', 'email', 'gender']) &&
        request.resource.data.keys().hasAll(['name', 'email', 'gender']);
    }

    function isValidProfileData() {
      return request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 80 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        request.resource.data.gender is string &&
        request.resource.data.gender in ['MASCULINO', 'FEMININO', 'OUTRO'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        hasOnlyAllowedProfileFields() &&
        isValidProfileData();
      allow delete: if isOwner(userId);
    }
  }
}
